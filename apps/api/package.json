    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@trustcrm/eslint-config": "workspace:*",
    "@trustcrm/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.7.0",
